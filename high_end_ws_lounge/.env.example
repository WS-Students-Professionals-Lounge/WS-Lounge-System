# High End WS Lounge Environment Configuration
SECRET_KEY=your-super-secret-key-change-in-production

# Database
SQLALCHEMY_DATABASE_URI=mysql://user:pass@localhost/ws_lounge_lapaz?charset=utf8mb4

# Mail (Gmail example)
